# ============================================================
# 生产环境变量模板
# 使用方法：复制为 .env.prod 并填入真实值
#   cp .env.prod.example .env.prod
# ============================================================
# 注意：.env.prod 含有敏感信息，切勿提交到 Git

# -------------------- 后端应用 --------------------
SPRING_PROFILES_ACTIVE=prod

# 数据库连接（当 PostgreSQL 与 backend 在同一 compose 中时，
# DB_URL 由 docker-compose 自动设置为 postgres:5432，此处仅作文档说明）
DB_URL=jdbc:postgresql://postgres:5432/ai_learning
DB_USERNAME=postgres
DB_PASSWORD=你的数据库密码

# -------------------- PostgreSQL（compose 内建库）--------------------
POSTGRES_DB=ai_learning

# -------------------- Docker 镜像 --------------------
# 替换为你的 GHCR 镜像地址，例如：ghcr.io/zhangsan/ai-learning-backend:latest
BACKEND_IMAGE=ghcr.io/<github-username>/ai-learning-backend:latest
