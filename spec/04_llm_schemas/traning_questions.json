{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "EvaluatorTrainingQuestionsOutput",
    "type": "object",
    "additionalProperties": false,
    "required": ["questions"],
    "properties": {
      "questions": {
        "type": "array",
        "minItems": 2,
        "maxItems": 6,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "prompt", "rubric", "key_points"],
          "properties": {
            "id": { "type": "string", "minLength": 1, "maxLength": 24 },
            "type": {
              "type": "string",
              "enum": ["short_answer", "multiple_choice", "true_false"]
            },
            "prompt": { "type": "string", "minLength": 10, "maxLength": 800 },
            "options": {
              "type": "array",
              "items": { "type": "string", "minLength": 1, "maxLength": 200 },
              "minItems": 2,
              "maxItems": 6
            },
            "answer": {
              "type": "string",
              "minLength": 1,
              "maxLength": 600
            },
            "key_points": {
              "type": "array",
              "items": { "type": "string", "minLength": 1, "maxLength": 200 },
              "minItems": 2,
              "maxItems": 10
            },
            "rubric": {
              "type": "object",
              "additionalProperties": false,
              "required": ["max_score", "criteria"],
              "properties": {
                "max_score": { "type": "integer", "minimum": 10, "maximum": 100 },
                "criteria": {
                  "type": "array",
                  "minItems": 2,
                  "maxItems": 8,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["name", "points"],
                    "properties": {
                      "name": { "type": "string", "minLength": 1, "maxLength": 60 },
                      "points": { "type": "integer", "minimum": 1, "maximum": 80 },
                      "description": { "type": "string", "minLength": 1, "maxLength": 240 }
                    }
                  }
                }
              }
            }
          },
          "allOf": [
            {
              "if": { "properties": { "type": { "const": "multiple_choice" } } },
              "then": { "required": ["options", "answer"] }
            },
            {
              "if": { "properties": { "type": { "const": "true_false" } } },
              "then": { "required": ["answer"] }
            },
            {
              "if": { "properties": { "type": { "const": "short_answer" } } },
              "then": { "required": ["answer"] }
            }
          ]
        }
      }
    }
  }