
{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "EvaluatorEvaluationOutput",
    "type": "object",
    "additionalProperties": false,
    "required": ["score", "error_tags", "feedback", "mastery_delta"],
    "properties": {
      "score": { "type": "integer", "minimum": 0, "maximum": 100 },
      "error_tags": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "CONCEPT_CONFUSION",
            "MISSING_STEPS",
            "BOUNDARY_CASE",
            "TERMINOLOGY",
            "SHALLOW_REASONING",
            "MEMORY_GAP"
          ]
        },
        "minItems": 0,
        "maxItems": 6,
        "uniqueItems": true
      },
      "feedback": {
        "type": "object",
        "additionalProperties": false,
        "required": ["diagnosis", "fixes"],
        "properties": {
          "diagnosis": { "type": "string", "minLength": 1, "maxLength": 900 },
          "fixes": {
            "type": "array",
            "items": { "type": "string", "minLength": 1, "maxLength": 220 },
            "minItems": 1,
            "maxItems": 8
          }
        }
      },
      "mastery_delta": {
        "type": "number",
        "minimum": -0.30,
        "maximum": 0.30
      }
    }
  }